# LLM Provider (pick one)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# ProductHunt (optional - for GraphQL API)
PRODUCTHUNT_API_TOKEN=your_ph_token_here

# Campaign Config
LAUNCH_DATE=2026-05-10
DAILY_CONNECTION_BUDGET=13
PH_LAUNCH_URL=https://www.producthunt.com/posts/your-product

# Server
# Uncomment to restrict to localhost only (local dev). Cloud deploys need 0.0.0.0 (the default).
# HOST=127.0.0.1
PORT=3847

# Database path — set to a Railway/Render volume path for persistence across deploys
# DB_PATH=/data/wingman.db
