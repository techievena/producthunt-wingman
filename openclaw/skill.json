{
  "name": "ph-wingman",
  "version": "1.3.0",
  "description": "AI-native ProductHunt outreach agent — automates community discovery, enrichment, and LinkedIn engagement.",
  "author": "techievena",
  "license": "MIT",
  "source": "https://github.com/techievena/producthunt-wingman",
  "homepage": "https://producthunt.eonik.ai",
  "tags": [
    "producthunt",
    "outreach",
    "linkedin",
    "marketing",
    "automation"
  ],
  "triggers": [
    "Start my PH outreach",
    "Set up wingman",
    "Scrape ProductHunt streaks",
    "How many connections did wingman send today?",
    "Check my launch outreach status",
    "Pause wingman",
    "cron"
  ],
  "schedule": "0 9 * * *",
  "dependencies": {
    "python": ">=3.9"
  },
  "requiredEnv": [
    "OPENAI_API_KEY"
  ],
  "requirements": {
    "bins": [
      "python3",
      "curl"
    ]
  },
  "config_required": true,
  "readme": "README.md",
  "skill_file": "SKILL.md"
}
